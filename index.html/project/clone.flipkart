<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Flipkart Clone</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #f1f3f6;
}

/* Header */
header {
  background: #2874f0;
  color: white;
  display: flex;
  align-items: center;
  padding: 10px 20px;
}

.logo {
  font-size: 22px;
  font-weight: bold;
}

.search-box {
  margin-left: 20px;
  flex: 1;
}

.search-box input {
  width: 60%;
  padding: 8px;
  border: none;
}

.search-box button {
  padding: 8px;
  background: #ffe500;
  border: none;
  cursor: pointer;
}

.nav-links {
  margin-left: 20px;
}

.nav-links a {
  color: white;
  margin-left: 15px;
  text-decoration: none;
}

/* Categories */
.categories {
  display: flex;
  justify-content: space-around;
  background: white;
  padding: 15px;
}

.categories div {
  text-align: center;
  font-size: 14px;
}

/* Banner */
.banner {
  background: #ddd;
  height: 200px;
  margin: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

/* Products */
.products {
  display: flex;
  flex-wrap: wrap;
  padding: 10px;
}

.card {
  background: white;
  width: 200px;
  margin: 10px;
  padding: 10px;
  text-align: center;
  border: 1px solid #ddd;
}

.card img {
  width: 100%;
  height: 150px;
  object-fit: cover;
}

.card button {
  background: #2874f0;
  color: white;
  border: none;
  padding: 8px;
  margin-top: 10px;
  cursor: pointer;
}

/* Footer */
footer {
  background: #172337;
  color: white;
  text-align: center;
  padding: 15px;
  margin-top: 20px;
}
</style>
</head>

<body>

<!-- Header -->
<header>
  <div class="logo">Flipkart</div>

  <div class="search-box">
    <input type="text" placeholder="Search for products">
    <button>Search</button>
  </div>

  <div class="nav-links">
    <a href="#">Login</a>
    <a href="#">Cart</a>
  </div>
</header>

<!-- Categories -->
<div class="categories">
  <div>Mobiles</div>
  <div>Fashion</div>
  <div>Electronics</div>
  <div>Home</div>
  <div>Appliances</div>
</div>

<!-- Banner -->
<div class="banner">
  Big Billion Sale
</div>

<!-- Products -->
<div class="products">

  <div class="card">
    <img src="https://via.placeholder.com/200">
    <h4>Smartphone</h4>
    <p>₹12,999</p>
    <button>Add to Cart</button>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/200">
    <h4>Laptop</h4>
    <p>₹45,000</p>
    <button>Add to Cart</button>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/200">
    <h4>Headphones</h4>
    <p>₹1,999</p>
    <button>Add to Cart</button>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/200">
    <h4>Shoes</h4>
    <p>₹2,499</p>
    <button>Add to Cart</button>
  </div>

</div>

<!-- Footer -->
<footer>
  © 2026 Flipkart Clone | For Learning Purpose
</footer>

</body>
</html>
